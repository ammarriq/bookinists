---
import Dropdown from './Header.svelte'

const user = Astro.locals.user

const menu = [{ isPost: true, label: 'Logout', url: '/api/logout' }]
---

<header
  class="fixed top-0 left-0 lg:left-56 right-0
  bg-white flex items-center px-4 h-11 border-b"
>
  <Dropdown client:load menu={menu} picture={user?.picture} />
</header>
