---
import Header from '@/lib/partials/Header.astro'
import Sidebar from '@/lib/partials/Sidebar.astro'
import BaseLayout from './BaseLayout.astro'

interface Props {
  title: string
}

const { title } = Astro.props
const { url, currentLocale } = Astro
---

<BaseLayout title={title}>
  <main class="relative bg-violet-50/80">
    <Header />
    <Sidebar />

    <div class="ml-0 lg:ml-56 mt-10 min-h-[calc(100vh-2.5rem)]">
      <slot />
    </div>
  </main>
</BaseLayout>
